# Copy to ~/.cloudflared/config.yml after: cloudflared tunnel create <name>
#
# Route DNS (one-time):
#   cloudflared tunnel route dns <name> api.mint.example.com
#
# Login (one-time, interactive):
#   cloudflared tunnel login

tunnel: <TUNNEL_UUID>
credentials-file: /home/<USER>/.cloudflared/<TUNNEL_UUID>.json

ingress:
  - hostname: api.mint.example.com
    service: http://localhost:3338
  - service: http_status:404
