# Copy to .env and fill in. NEVER commit .env.

# Bitcoin Core JSON-RPC (your node — localhost, VPN, or private network)
BITCOIN_RPC_URL=http://127.0.0.1:8332
BITCOIN_RPC_USER=bitcoinrpc
BITCOIN_RPC_PASSWORD=change-me

# Ark ASP — mock (default), barkd (Second signet), or arkade
# ARK_BACKEND=mock
# ARK_BACKEND=barkd
# ARK_BACKEND=arkade
ARK_SERVER_URL=https://asp.example.com
ARK_SERVER_PUBKEY=
# BARKD_URL=http://127.0.0.1:3535
# ARK_WALLET_URL=http://127.0.0.1:3535
# BARKD_AUTH_TOKEN=
# ARKADE_WALLET_AUTH_TOKEN=

# Melt payout — inherit (default), mock, or barkd
# MELT_BACKEND=inherit

# Unilateral exit: auto-sweep claimable VTXOs to an on-chain address (barkd/arkade wallet)
# ARK_EXIT_CLAIM_ADDRESS=tb1...
# ARK_AUTO_CLAIM_EXITS=true

# Blind signing — mock (default), remote (cdk-signatory gRPC), or local (dev dhke)
# SIGNATORY_BACKEND=mock
# SIGNATORY_BACKEND=remote
# SIGNATORY_URL=http://127.0.0.1:3340
# SIGNATORY_TLS_DIR=/path/to/signatory-tls
# SIGNATORY_MINT_SECRET=<64-hex dev-only mint secret for local backend>

# Optional overrides
# MINERVA_CONFIG=config.toml
# MINERVA_MINT_URL=https://mint.example.com
# MINERVA_OTS_ENABLED=false
# BIND_ADDR=127.0.0.1:3338
# DATABASE_PATH=data/minerva.sqlite

RUST_LOG=minerva_mint=info,tower_http=info
